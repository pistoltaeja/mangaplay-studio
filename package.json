{
    "name": "mangaplay-studio",
    "version": "1.0.1",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun scripts/copy-assets.js && bun scripts/template-tauri-conf.js && bun scripts/build-bundle.js && bun scripts/serve-static.js 5050 & sleep 1 && bun x tauri dev",
        "build": "bun scripts/copy-assets.js && bun scripts/template-tauri-conf.js && bun scripts/build-bundle.js --minify && bun x tauri build",
        "build:windows": "bun scripts/build-app.js --windows",
        "build:windows-dev": "bun scripts/build-app.js --windows --dev",
        "build:windows-mobile": "bun scripts/build-app.js --windows --ux-mode=mobile",
        "build:windows-tablet": "bun scripts/build-app.js --windows --ux-mode=tablet",
        "build:osx": "bun scripts/build-app.js --osx",
        "build:osx-dev": "bun scripts/build-app.js --osx --dev",
        "build:osx-mobile": "bun scripts/build-app.js --osx --ux-mode=mobile",
        "build:osx-tablet": "bun scripts/build-app.js --osx --ux-mode=tablet",
        "build:android": "bun scripts/build-app.js --android",
        "build:android-dev": "bun scripts/build-app.js --android --dev",
        "bench:cold-start": "MPS_USE_DEV_EXE=1 bun tests/driver/benchmark-cold-start.js",
        "web": "bun scripts/copy-assets.js && bun scripts/build-bundle.js && bun --bun serve build/mangaplay-studio/frontend",
        "copy-assets": "bun scripts/copy-assets.js",
        "test": "bun test tests/bundle.test.js tests/editor.test.js tests/project.test.js tests/drawing/mangaart-roundtrip.test.js tests/drawing/pointer-coords.test.js tests/drawing/strokes-perf.test.js tests/shell/shell-restore.test.js tests/shell/theme.test.js tests/shell/user-settings.test.js tests/validate-basename.test.js tests/active-script-broker.test.js tests/fakefs.test.js tests/context-menu.test.js tests/editor-clipboard.test.js tests/font-loader.test.js tests/font-matrix.test.js tests/picker-shell-i18n.test.js tests/tooltip-i18n.test.js tests/folder-tree.test.js tests/screenplay-metadata.test.js tests/superscript-screenplay.test.js tests/grammar-table.test.js tests/cross-format-roundtrip.test.js tests/system-locale-detector.test.js tests/spellcheck-tier.test.js tests/editor-checks-sequential-pages.test.js tests/superscript-reader.test.js",
        "test:screenplay-full": "bun test tests/screenplay.test.js",
        "test:grammar": "bun test tests/grammar.test.js",
        "grammar:build": "bun x @lezer/generator grammar/mangaplay.grammar -o grammar/mangaplay.grammar.js",
        "test:rust": "cd src-tauri && cargo test --test atomic_write --test mangaart_scaffold --test app_settings --test list_project_scripts --test list_project_tree --test validate_basename --test next_free_name --test fs_commands --test fs_folder_ops --test layout_v2 --test flatten_migration --test move_path --test user_data_store",
        "test:webdriver": "bun tests/driver/run.js",
        "test:app": "bun tests/driver/click-smoke.js",
        "test:app:ux-mode": "MPS_USE_DEV_EXE=1 bun tests/driver/ux-mode-smoke.js",
        "test:grammar-check": "bun run scripts/build-bundle.js && bun run tests/driver/grammar-check-smoke.js",
        "test:typing-autos": "bun run scripts/build-bundle.js && bun run tests/driver/typing-autos-smoke.js",
        "test:folding": "bun run scripts/build-bundle.js && bun run tests/driver/folding-smoke.js",
        "test:app:i18n": "bun tests/driver/verify-i18n-live.js",
        "test:app:ctx-guard": "bun tests/driver/verify-ctx-guard.js",
        "test:app:ctx-component": "bun tests/driver/verify-ctx-component.js",
        "test:app:ctx-file-swap": "bun tests/driver/verify-ctx-file-swap.js",
        "test:app:real-os-mouse": "bun tests/driver/verify-real-os-mouse.js",
        "test:app:ctx-editor": "bun tests/driver/verify-ctx-editor.js",
        "test:app:explorer-dnd": "bun tests/driver/explorer-dnd-os.js",
        "test:app:font-settings": "bun tests/driver/font-settings-smoke.js",
        "test:app:screenplay-font": "bun tests/driver/screenplay-font-verify.js",
        "test:app:lifecycle": "bun tests/driver/verify-lifecycle.js",
        "test:app:picker": "bun tests/driver/verify-picker.js",
        "test:app:tabs": "bun tests/driver/verify-tabs.js",
        "test:baseline": "bun tests/driver/verify-baseline.js",
        "test:baseline:approve": "MPS_BASELINE_APPROVE=1 bun tests/driver/verify-baseline.js",
        "test:draw-engine": "bun tests/driver/run-draw-engine.js",
        "test:draw-engine:stress": "MPS_DRAW_STRESS_PROFILE=full bun tests/driver/run-draw-engine.js",
        "test:draw-engine:leak": "MPS_DRAW_STRESS_PROFILE=leak MPS_DRAW_LEAK_BUDGET_MB=80 bun tests/driver/run-draw-engine.js",
        "gen:storyboard-100-fixture": "bun scripts/gen-storyboard-100-fixture.js",
        "test:settings-standalone": "bun tests/driver/run-settings-standalone.js",
        "test:left-pane": "MPS_USE_DEV_EXE=1 bun tests/driver/verify-left-pane.js",
        "test:visual-editor-roundtrip": "MPS_USE_DEV_EXE=1 bun tests/driver/verify-visual-editor-roundtrip.js",
        "test:visual-editor-dorothy": "MPS_USE_DEV_EXE=1 bun tests/driver/verify-visual-editor-dorothy.js",
        "test:visual-editor-chips": "MPS_USE_DEV_EXE=1 bun tests/driver/verify-visual-editor-chips.js",
        "test:export-screenplay-pdf": "MPS_USE_DEV_EXE=1 bun tests/driver/verify-export-screenplay-pdf.js",
        "test:fix-structural-issues": "MPS_USE_DEV_EXE=1 bun tests/driver/verify-fix-structural-issues.js",
        "test:fix-structural-issues-fountain": "MPS_USE_DEV_EXE=1 bun tests/driver/verify-fix-structural-issues-fountain.js",
        "bench:dev": "MPS_USE_DEV_EXE=1 bun tests/driver/benchmark-smoke.js",
        "smoke:11": "bun run test && bun run test:rust && bun run test:webdriver"
    },
    "devDependencies": {
        "@lezer/generator": "1.8.0",
        "@lezer/lr": "1.4.10",
        "@tauri-apps/cli": "^2.11.2",
        "ajv": "^8.17.1",
        "js-yaml": "^4.1.0",
        "jsdom": "29.1.1",
        "pixelmatch": "7.2.0",
        "playwright": "1.60.0",
        "resize-observer-polyfill": "1.5.1",
        "webdriverio": "9.28.0"
    },
    "dependencies": {
        "@codemirror/autocomplete": "6.20.3",
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/language": "^6.12.3",
        "@codemirror/lint": "^6.8.0",
        "@codemirror/state": "^6.6.0",
        "@codemirror/view": "^6.43.1",
        "@lezer/highlight": "1.2.3",
        "@tauri-apps/api": "^2.11.0",
        "@tauri-apps/plugin-clipboard-manager": "^2.3.0",
        "@tauri-apps/plugin-os": "^2.0.0",
        "@tauri-apps/plugin-shell": "2.3.5",
        "harper.js": "^2.4.0",
        "lucide": "1.17.0"
    }
}
